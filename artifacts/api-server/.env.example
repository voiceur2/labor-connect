# Set these in Render dashboard → Environment → Environment Variables

# PostgreSQL connection string from Neon (neon.tech)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Comma-separated list of allowed frontend origins (your Vercel URL)
ALLOWED_ORIGINS=https://labor-connect.vercel.app

# Auto-generated by Render, or set your own secret string
SESSION_SECRET=change-me-to-a-long-random-string

NODE_ENV=production
